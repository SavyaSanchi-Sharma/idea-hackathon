# Node / Vite (frontend)
node_modules
dist
dist-ssr
.vite
*.local

# Python (ai_engine)
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
.ipynb_checkpoints/

# Trained model artifacts — joblib files MUST ship for Docker/Render
# Only exclude Python cache and the large split-snapshot (not needed at inference)
ai_engine/train/models/**/__pycache__/
ai_engine/train/models/**/*.pyc
ai_engine/train/models/classifier/artifacts/splits.joblib

# Rust build artifacts
target/
**/target/

# Cargo flycheck (rust-analyzer)
**/.flycheck/
**/flycheck0/

# SQLite runtime state (backend stores) — covers any .db at any path
*.db
*.db-shm
*.db-wal
pipe/backend/data/

# Backend ad-hoc logs / pids
*.log
*.pid

# HuggingFace model cache (when run from repo dir)
.cache/huggingface/

# Environment / secrets
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code local config
.claude/
